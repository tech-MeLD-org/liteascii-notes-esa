---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'LiteASCII',
  description = '探索知识的边界，连接思想的星图',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <slot />

    <script is:inline>
      window.__pagefind_ready = false;
      // 将 _pagefind 全部替换为 pagefind
      fetch('/pagefind/pagefind-ui.js').then(r => {
        if (r.ok) {
          const s = document.createElement('script');
          s.src = '/pagefind/pagefind-ui.js';
          s.onload = () => { window.__pagefind_ready = true; };
          document.head.appendChild(s);
        }
      }).catch(() => {});
    </script>
  </body>
</html>

<style is:global>
  /* ====== 统一 Meta 标签样式 ====== */
  .meta-group {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }

  /* ====== 统一“全卡片点击”交互逻辑 ====== */
  .card-click-wrapper {
    position: relative;
    cursor: pointer;
  }
  .card-main-link {
    text-decoration: none;
    color: inherit;
    display: inline-block;
  }
  /* 利用 ::before 覆盖整个相对定位的父级卡片 */
  .card-main-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
  }
</style>
