---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'LiteASCII',
  description = '探索知识的边界，连接思想的星图',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Pagefind UI (available after `pnpm build`) -->
    <link rel="stylesheet" href="/_pagefind/pagefind-ui.css" />

    <!-- Prevent flash of wrong theme: dark is default (no attr), light = data-theme="light" -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
        // dark is default CSS :root — no attribute needed
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Pagefind UI script (available after build) -->
    <script is:inline>
      // Only load pagefind in production build
      window.__pagefind_ready = false;
      fetch('/_pagefind/pagefind-ui.js').then(r => {
        if (r.ok) {
          const s = document.createElement('script');
          s.src = '/_pagefind/pagefind-ui.js';
          s.onload = () => { window.__pagefind_ready = true; };
          document.head.appendChild(s);
        }
      }).catch(() => {});
    </script>
  </body>
</html>




<style is:global>
  /* ====== 统一 Meta 标签样式 ====== */
  .meta-group { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; position: relative; z-index: 2; }
  
  .pill-category {
    font-size: 0.7rem; font-weight: 600; color: #ff5e4d; 
    background: rgba(255, 94, 77, 0.08); padding: 0.2rem 0.6rem; 
    border-radius: 4px; text-decoration: none; font-family: 'Courier New', monospace; 
    transition: all 0.2s;
  }
  .pill-category:hover { background: rgba(255, 94, 77, 0.15); color: #ff4133; }
  
  .pill-tags-group { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .pill-tag {
    font-size: 0.7rem; color: var(--text-2); background: var(--bg-2);
    padding: 0.15rem 0.5rem; border-radius: 4px; font-family: 'Courier New', monospace; 
    text-decoration: none; transition: all 0.2s;
  }
  .pill-tag:hover { background: var(--border); color: var(--text); }

  /* ====== 统一“全卡片点击”交互逻辑 ====== */
  .card-click-wrapper { position: relative; cursor: pointer; }
  .card-main-link { text-decoration: none; color: inherit; display: inline-block; }
  /* 利用 ::before 覆盖整个相对定位的父级卡片 */
  .card-main-link::before { content: ""; position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 1; }
</style>