---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand-name">LiteASCII</a>
      <p class="brand-desc">知识生长于链接之中</p>
    </div>

    <nav class="footer-nav">
      <a href="/">Home</a>
      <a href="/notes">Notes</a>
      <a href="/timeline">Timeline</a>
      <a href="/about">About</a>
    </nav>

    <p class="footer-copy">© {year} · Built with Astro & Svelte</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-2);
    margin-top: 4rem;
    padding: 2rem 1.5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand { flex: 1; min-width: 160px; }

  .brand-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--red);
    letter-spacing: 0.03em;
  }
  .brand-name:hover { color: var(--red-2); }

  .brand-desc {
    font-size: 0.75rem;
    color: var(--text-3);
    margin: 0.25rem 0 0;
    font-family: 'Courier New', monospace;
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-nav a {
    font-size: 0.8rem;
    color: var(--text-2);
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--red); }

  .footer-copy {
    width: 100%;
    font-size: 0.72rem;
    color: var(--text-3);
    margin: 0.5rem 0 0;
    font-family: 'Courier New', monospace;
  }
</style>
