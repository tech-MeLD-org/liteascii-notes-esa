---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand-name">LiteASCII</a>
      <p class="brand-desc">知识生长于链接之中</p>
    </div>

    <!-- 导航链接已移除 -->

    <p class="footer-copy">© {year} · Built with Astro & Svelte</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-2);
    margin-top: 4rem;
    padding: 2rem 1.5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-brand { flex: 1; min-width: 160px; }

  .brand-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--red);
    letter-spacing: 0.03em;
  }
  .brand-name:hover { color: var(--red-2); }

  .brand-desc {
    font-size: 0.75rem;
    color: var(--text-3);
    margin: 0.25rem 0 0;
    font-family: 'Courier New', monospace;
  }

  .footer-copy {
    font-size: 0.72rem;
    color: var(--text-3);
    margin: 0;
    font-family: 'Courier New', monospace;
  }
</style>
