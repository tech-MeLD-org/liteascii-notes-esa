---
// Profile 卡片组件 - 显示站点信息和统计
interface Props {
  notesCount: number;
  categoriesCount: number;
  tagsCount: number;
}

const { notesCount, categoriesCount, tagsCount } = Astro.props;
---

<div class="profile-card">
  <div class="profile-avatar">
    <img src="/favicon.svg" alt="LiteASCII" class="avatar-img" />
  </div>
  <h3 class="profile-name">LiteASCII</h3>
  <p class="profile-desc">知识生长于链接之中</p>
  <div class="profile-stats">
    <a href="/notes" class="stat-item">
      <span class="stat-num">{notesCount}</span>
      <span class="stat-label">Notes</span>
    </a>
    <div class="stat-divider"></div>
    <a href="/notes" class="stat-item">
      <span class="stat-num">{categoriesCount}</span>
      <span class="stat-label">Categories</span>
    </a>
    <div class="stat-divider"></div>
    <a href="/notes" class="stat-item">
      <span class="stat-num">{tagsCount}</span>
      <span class="stat-label">Tags</span>
    </a>
  </div>
</div>

<style>
  .profile-card {
    text-align: center;
    padding: 1.5rem 1.25rem;
  }
  .profile-avatar {
    width: 72px;
    height: 72px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--red);
    padding: 3px;
    transition: transform 0.3s ease;
  }
  .profile-avatar:hover {
    transform: scale(1.05);
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: var(--bg-2);
  }
  .profile-name {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .profile-desc {
    font-size: 0.8rem;
    color: var(--text-3);
    margin: 0 0 1.5rem;
    opacity: 0.9;
    line-height: 1.5;
  }
  .profile-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    padding: 0.5rem;
    border-radius: 6px;
    transition: background 0.2s;
    min-width: 60px;
  }
  .stat-item:hover {
    background: var(--bg-2);
  }
  .stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    font-family: 'Courier New', monospace;
    line-height: 1.2;
  }
  .stat-label {
    font-size: 0.65rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.2rem;
  }
  .stat-divider {
    width: 1px;
    height: 24px;
    background: var(--border);
    opacity: 0.5;
  }
</style>