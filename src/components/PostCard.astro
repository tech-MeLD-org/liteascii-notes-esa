---
interface Props {
  title: string;
  href: string;
  date?: Date | string;
  description?: string;
  tags?: string[];
  category?: string;
}

const { title, href, date, description, tags = [], category } = Astro.props;

const dateStr = date
  ? new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
  : null;
---

<article class="post-card">
  <a href={href} class="card-link">
    <div class="card-meta">
      {dateStr && <time class="card-date">{dateStr}</time>}
      {category && <span class="card-cat">{category}</span>}
    </div>
    <h3 class="card-title">{title}</h3>
    {description && <p class="card-desc">{description}</p>}
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(tag => <span class="red-tag">{tag}</span>)}
      </div>
    )}
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-card);
    transition: border-color 0.15s, transform 0.15s;
  }
  .post-card:hover {
    border-color: var(--red);
    transform: translateY(-1px);
  }

  .card-link {
    display: block;
    padding: 1rem 1.25rem;
    color: inherit;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .card-date {
    font-size: 0.72rem;
    color: var(--text-3);
    font-family: 'Courier New', monospace;
  }

  .card-cat {
    font-size: 0.68rem;
    color: var(--red);
    font-family: 'Courier New', monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.4rem;
    line-height: 1.4;
    transition: color 0.15s;
  }
  .post-card:hover .card-title { color: var(--red); }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-2);
    margin: 0 0 0.6rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
