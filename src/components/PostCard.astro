---
interface Props {
  title: string;
  href: string;
  date?: Date | string;
  description?: string;
  tags?: string[];
  category?: string;
}

const { title, href, date, description, tags = [], category } = Astro.props;
function formatDate(dateVal) {
  if (!dateVal) return "";
  const d = new Date(dateVal);
  return d.toISOString().split("T")[0];
}
const dateStr = date
  ? new Date(date).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    })
  : null;
---

<article class="post-card card-click-wrapper">
  {date && <time class="card-date">{formatDate(date)}</time>}

  <a href={href} class="card-main-link">
    <h3 class="card-title">{title}</h3>
  </a>

  {description && <p class="card-desc">{description}</p>}

  <div class="meta-group" style="margin-top: auto; padding-top: 1rem;">
    {
      category && (
        <a href={`/category/${category}`} class="pill-category">
          {category}
        </a>
      )
    }
    {
      tags && tags.length > 0 && (
        <div class="pill-tags-group">
          {tags.map((t) => (
            <a href={`/tags/${t}`} class="pill-tag">
              #{t}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--bg-card, #1a1a1a);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition:
      transform 0.2s,
      border-color 0.2s;
    height: 100%;
  }
  .post-card:hover {
    border-color: var(--red);
    transform: translateY(-3px);
  }
  .card-date {
    font-size: 0.75rem;
    color: var(--text-3);
    font-family: "Courier New", monospace;
    margin-bottom: 0.5rem;
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    transition: color 0.2s;
  }
  .post-card:hover .card-title {
    color: var(--red);
  }
  .card-desc {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link {
    display: block;
    padding: 1rem 1.25rem;
    color: inherit;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .card-date {
    font-size: 0.72rem;
    color: var(--text-3);
    font-family: "Courier New", monospace;
  }

  .card-cat {
    font-size: 0.68rem;
    color: var(--red);
    font-family: "Courier New", monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.4rem;
    line-height: 1.4;
    transition: color 0.15s;
  }
  .post-card:hover .card-title {
    color: var(--red);
  }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-2);
    margin: 0 0 0.6rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
