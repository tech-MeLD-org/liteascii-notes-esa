---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.svelte';
import NoteExplorerSidebar from '../../components/NoteExplorerSidebar.svelte';
import Footer from '../../components/Footer.astro';
import { isVisibleNote, pathToSlug, getNoteTitle } from '../../utils/note-logic';

export async function getStaticPaths() {
  const noteEntries = await getCollection('notes');
  const validNotes = noteEntries.filter(isVisibleNote);
  return validNotes.map(entry => ({
    params: { slug: pathToSlug(entry.id) },
    props: { entry, allNotes: validNotes },
  }));
}

const { entry, allNotes } = Astro.props;
const { Content, headings } = await render(entry); 
const title = getNoteTitle(entry);
const currentSlug = pathToSlug(entry.id);

const { tags = [], category, date } = entry.data;
const dateStr = date
  ? new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
  : null;

// 修改：显示 1-3 级标题
const filteredHeadings = headings.filter(h => h.depth >= 1 && h.depth <= 3);
---

<Layout title={`${title} · LiteASCII`}>
  <Navigation client:load />

  <div class="page-container">
    <div class="three-column-layout">
      <NoteExplorerSidebar client:load allNotes={allNotes} currentSlug={currentSlug} />

      <main class="content-column">
        <article class="prose">
          <header class="note-header">
            <a href="/" class="back-link">← BACK</a>
            <div class="note-meta">
              {dateStr && <time class="meta-date">{dateStr}</time>}
              {category && <span class="meta-category">{category}</span>}
            </div>
            <h1 class="note-title">{title}</h1>
            {tags.length > 0 && (
              <div class="note-tags">
                {tags.map(tag => <span class="note-tag">#{tag}</span>)}
              </div>
            )}
          </header>

          <section class="markdown-body">
            <Content />
          </section>
        </article>
      </main>

      <aside class="toc-column">
        <div class="toc-inner">
          <div class="toc-label">ON THIS PAGE</div>
          <nav id="toc-nav">
            {filteredHeadings.map((h) => (
              <a href={`#${h.slug}`} class={`toc-item d-${h.depth}`} title={h.text}>
                <span class="toc-text">{h.text}</span>
              </a>
            ))}
          </nav>
        </div>
      </aside>
    </div>
    <Footer />
  </div>
</Layout>

<script>
  let isClickScrolling = false;
  let scrollTimeout: any = null;

  function setActiveHeading(id: string) {
    document.querySelectorAll('#toc-nav a').forEach(a => a.classList.remove('active'));
    const activeLink = document.querySelector(`#toc-nav a[href="#${id}"]`);
    if (activeLink) {
      activeLink.classList.add('active');
      activeLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  }

  const headingElements = Array.from(
    document.querySelectorAll('.markdown-body h1, .markdown-body h2, .markdown-body h3')
  ).filter(h => h.id) as HTMLElement[];

  function updateTocOnScroll() {
    if (isClickScrolling || headingElements.length === 0) return;
    const triggerLine = window.scrollY + 120;
    let currentHeading = headingElements[0];
    for (const h of headingElements) {
      if (h.offsetTop <= triggerLine) currentHeading = h;
      else break;
    }
    setActiveHeading(currentHeading.id);
  }

  window.addEventListener('scroll', () => requestAnimationFrame(updateTocOnScroll), { passive: true });
  updateTocOnScroll();

  document.querySelectorAll('#toc-nav a').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const targetSlug = (e.currentTarget as HTMLAnchorElement).getAttribute('href')?.slice(1);
      if (!targetSlug) return;
      const targetEl = document.getElementById(targetSlug);
      if (targetEl) {
        isClickScrolling = true;
        setActiveHeading(targetSlug);
        window.scrollTo({ top: targetEl.offsetTop - 100, behavior: 'smooth' });
        if (scrollTimeout) clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => { isClickScrolling = false; }, 1500);
      }
    });
  });
</script>

<style>
  .page-container { margin-top: var(--nav-h); display: flex; flex-direction: column; }
  .three-column-layout { display: flex; width: 100%; max-width: 1600px; margin: 0 auto; justify-content: center; }

  .content-column { flex: 1; min-width: 0; max-width: 860px; padding: 2.5rem 4rem 5rem; }

  /* ── 右侧 TOC：调暗亮度 & 增加层级感 ── */
  .toc-column {
    width: 240px; flex-shrink: 0; position: sticky; top: calc(var(--nav-h) + 2rem);
    height: fit-content; max-height: calc(100vh - var(--nav-h) - 4rem);
    overflow-y: auto; scrollbar-width: none; overscroll-behavior: contain;
  }
  .toc-column::-webkit-scrollbar { display: none; }

  .toc-inner { border-left: 1px solid var(--border); padding-left: 0.5rem; margin-left: 1rem; }
  .toc-label { 
    font-size: 0.65rem; font-weight: 700; color: var(--text-3); 
    margin-bottom: 1.2rem; letter-spacing: 0.1em; padding-left: 0.8rem;
    opacity: 0.5; /* 调得比左侧略淡，更显安静 */
  }
  
  .toc-item {
    display: flex; align-items: center; text-decoration: none;
    padding: 0.35rem 0.8rem; line-height: 1.4; transition: all 0.2s;
    border-radius: 4px; margin-bottom: 2px;
    color: var(--text-3); /* 基色调暗 */
    opacity: 0.65; /* 初始亮度 */
  }
  .toc-text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* 阶梯缩进 */
  .d-1 { font-size: 0.82rem; font-weight: 500; padding-left: 0.8rem; }
  .d-2 { font-size: 0.78rem; padding-left: 1.6rem; opacity: 0.55; }
  .d-3 { font-size: 0.75rem; padding-left: 2.4rem; opacity: 0.45; }

  .toc-item:hover { background: var(--bg-2); color: var(--text-2); opacity: 1; }
  
  /* 激活状态 */
  .toc-item.active {
    background: var(--red-faint); color: var(--red); font-weight: 600; opacity: 1;
  }

  /* ── 其他样式 ── */
  .note-header { margin-bottom: 3.5rem; padding-bottom: 2rem; border-bottom: 1px dashed var(--border); }
  .back-link { font-size: 0.75rem; color: var(--text-3); text-decoration: none; margin-bottom: 1.5rem; display: inline-block; opacity: 0.7; }
  .note-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.8rem; }
  .meta-date { font-family: 'Courier New', monospace; font-size: 0.75rem; color: var(--text-3); }
  .meta-category { font-family: 'Courier New', monospace; font-size: 0.72rem; color: var(--red); font-weight: 600; text-transform: uppercase; }
  .note-title { font-size: 2.8rem; font-weight: 850; line-height: 1.15; margin: 0 0 1.2rem; }
  .note-tag { font-size: 0.75rem; color: var(--red); background: var(--red-faint); padding: 0.15rem 0.5rem; border-radius: 3px; font-family: 'Courier New', monospace; margin-right: 0.5rem; }

  @media (max-width: 1200px) { .toc-column { display: none; } }
  @media (max-width: 900px) { :global(.explorer-sidebar) { display: none; } .content-column { padding: 2rem 1.25rem; } }
</style>