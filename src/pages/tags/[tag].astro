---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.svelte';
import Footer from '../../components/layout/Footer.svelte';
import Sidebar from '../../components/layout/Sidebar.svelte';
import NoteList from '../../components/features/NoteList.svelte';
import PageHeader from '../../components/layout/PageHeader.svelte';
import { getCollection } from 'astro:content';
import { extractTitle, noteSlug, formatDate, countCategories, countTags } from '../../lib/core/note-logic';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  
  const tagMap = countTags(allNotes);
  const categoryMap = countCategories(allNotes);

  const tags = Array.from(tagMap.entries())
    .sort(([,a], [,b]) => b - a)
    .map(([name]) => name);

  const totalNotes = allNotes.length;
  
  return tags.map((tagName) => {
    const filteredNotes = allNotes.filter((note) => 
      note.data.tags?.includes(tagName)
    ).sort((a, b) => {
      const da = a.data.date ? new Date(a.data.date).getTime() : 0;
      const db = b.data.date ? new Date(b.data.date).getTime() : 0;
      return db - da;
    });
    
    // 将空格替换为横杠，用于URL友好的slug
    const tagSlug = tagName.replace(/\s+/g, '-');
    
    return {
      params: { tag: tagSlug },
      props: { 
        notes: filteredNotes, 
        tag: tagName, // 保持原始标签名用于显示
        tagSlug, // 添加slug版本
        totalNotes,
        categoryMap,
        tagMap
      },
    };
  });
}

const { tag } = Astro.params;
const { notes, totalNotes, categoryMap, tagMap, tag: originalTag } = Astro.props;

// 使用统一的横杠格式生成链接
const categories = Array.from(categoryMap.entries())
  .sort(([,a], [,b]) => b - a)
  .map(([name, count]) => ({ 
    name, 
    href: `/category/${name.replace(/\s+/g, '-')}`, 
    count 
  }));

const tags = Array.from(tagMap.entries())
  .sort(([,a], [,b]) => b - a)
  .map(([name, count]) => ({ 
    name, 
    href: `/tags/${name.replace(/\s+/g, '-')}`, 
    count 
  }));

const noteListData = notes.map(note => ({
  title: extractTitle(note),
  href: `/notes/${noteSlug(note.id)}`,
  date: formatDate(note.data.date),
  description: note.data.description,
  category: note.data.category as string | undefined,
  tags: note.data.tags || [],
}));
---

<Layout title={`Tag: ${tag} · LiteASCII`}>
  <Header client:load />
  
  <div class="pt-[calc(52px+2.5rem)] px-4 pb-16">
    <div class="flex w-full max-w-[1200px] mx-auto gap-10 items-start flex-col lg:flex-row">
      
      <aside class="w-full lg:w-[260px] flex-shrink-0">
        <Sidebar
          client:load
          noteCount={totalNotes}
          categoryCount={categoryMap.size}
          tagCount={tagMap.size}
          {categories}
          {tags}
          currentTag={tag}
          currentPath={`/tags/${tag}`}
        />
      </aside>

      <main class="flex-1 min-w-0 pb-12">
        <PageHeader
          client:load
          title={`#${tag}`}
          subtitle={`${notes.length} notes found in this tag`}
        />

        <NoteList 
          client:load
          notes={noteListData}
          emptyText="该标签下暂无笔记"
          highlightTag={tag}
        />
      </main>
      
    </div>
  </div>

  <Footer />
</Layout>