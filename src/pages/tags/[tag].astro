---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.svelte';
import Footer from '../../components/Footer.astro';
import ProfileCard from '../../components/ProfileCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  
  const tagCounts: Record<string, number> = {};
  const categoryCounts: Record<string, number> = {};

  allNotes.forEach(note => {
    (note.data.tags || []).forEach((tag: string) => {
      tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });
    if (note.data.category && typeof note.data.category === 'string') {
      const cat = note.data.category;
      categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
    }
  });

  const uniqueTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b] - tagCounts[a]);
  const uniqueCategories = Object.keys(categoryCounts).sort((a, b) => categoryCounts[b] - categoryCounts[a]);

  const totalNotes = allNotes.length;
  
  return uniqueTags.map((tag) => {
    const filteredNotes = allNotes.filter((note) => 
      note.data.tags?.includes(tag)
    ).sort((a, b) => {
      const da = a.data.date ? new Date(a.data.date).getTime() : 0;
      const db = b.data.date ? new Date(b.data.date).getTime() : 0;
      return db - da;
    });
    
    return {
      params: { tag },
      props: { 
        notes: filteredNotes, 
        allTags: uniqueTags,
        tagCounts,
        allCategories: uniqueCategories,
        categoryCounts,
        totalNotes
      },
    };
  });
}

const { tag } = Astro.params;
const { notes, allTags, tagCounts, allCategories, categoryCounts, totalNotes } = Astro.props;

function getTitle(note: any) {
  if (note.data.title) return note.data.title;
  const match = note.body?.match(/^#\s+(.+)/m);
  if (match) return match[1].trim();
  return note.id.replace(/\.md$/, '').split('/').pop() || 'Untitled';
}

function formatDate(dateVal: any) {
  if (!dateVal) return '--/--';
  const d = new Date(dateVal);
  return d.toISOString().split('T')[0];
}
---

<Layout title={`Tag: ${tag} · LiteASCII`}>
  <Navigation client:load />
  
  <div class="page-container">
    <div class="main-layout">
      
      <aside class="sidebar">
        <!-- Profile -->
        <div class="sidebar-box">
          <ProfileCard 
            notesCount={totalNotes} 
            categoriesCount={allCategories.length} 
            tagsCount={allTags.length} 
          />
        </div>

        <!-- Categories -->
        <div class="sidebar-box">
          <h3 class="box-title">CATEGORIES</h3>
          <ul class="category-list" id="category-list">
            <li class="category-item">
              <a href="/notes" class="category-link">
                <span class="cat-name">全部</span>
                <span class="cat-count">{totalNotes}</span>
              </a>
            </li>
            {allCategories.map((cat, index) => (
              <li class:list={['category-item', { 'is-hidden': index >= 6 }]}>
                <a href={`/category/${cat}`} class="category-link">
                  <span class="cat-name">{cat}</span>
                  <span class="cat-count">{categoryCounts[cat]}</span>
                </a>
              </li>
            ))}
          </ul>
          {allCategories.length > 6 && (
            <button id="cat-toggle-btn" class="toggle-btn">... 更多</button>
          )}
        </div>

        <!-- Tags -->
        <div class="sidebar-box">
          <h3 class="box-title">TAGS</h3>
          <div class="tags-list">
            {allTags.map(t => (
              <a href={`/tags/${t}`} class:list={['tag-item', { 'is-active': t === tag }]}>
                <span class="tag-symbol">#</span>{t}
                <span class="tag-num">{tagCounts[t]}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>

      <main class="content-area">
        <header class="content-header">
          <h1 class="content-title">
            <span class="title-symbol">#</span>{tag}
          </h1>
          <p class="content-subtitle">{notes.length} notes found in this tag</p>
        </header>

        <div class="notes-grid">
          {notes.map(note => (
            <article class="note-card">
              <div class="card-content">
                <time class="card-date">{formatDate(note.data.date)}</time>
                
                <a href={`/notes/${note.id.replace(/\.md$/, '')}`} class="card-title-link">
                  <h3 class="card-title">{getTitle(note)}</h3>
                </a>
                
                {note.data.description && (
                  <p class="card-desc">{note.data.description}</p>
                )}
                
                <div class="card-meta">
                  {note.data.category && (
                    <a href={`/category/${note.data.category}`} class="meta-cat">
                      {note.data.category}
                    </a>
                  )}
                  {note.data.tags && note.data.tags.length > 0 && (
                    <div class="meta-tags">
                      {note.data.tags.map((t: string) => (
                        <a href={`/tags/${t}`} class="meta-tag">#{t}</a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
              
              <span class="card-arrow">→</span>
            </article>
          ))}
        </div>
      </main>
      
    </div>
  </div>

  <Footer />
</Layout>

<script>
  const toggleBtn = document.getElementById('cat-toggle-btn');
  const categoryList = document.getElementById('category-list');
  
  if (toggleBtn && categoryList) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = categoryList.classList.toggle('is-expanded');
      toggleBtn.textContent = isExpanded ? '收起 ∧' : '... 更多';
    });
  }
</script>

<style>
  .page-container { 
    margin-top: var(--nav-h); 
    padding: 2.5rem 1rem;
  }
  
  .main-layout { 
    display: flex; 
    width: 100%; 
    max-width: 1200px; 
    margin: 0 auto; 
    gap: 2.5rem; 
    align-items: flex-start;
  }

  .sidebar { 
    width: 260px; 
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .sidebar-box { 
    border: 1px solid var(--border); 
    border-radius: 12px; 
    padding: 1.25rem; 
    background: var(--bg);
  }

  .box-title { 
    font-size: 0.7rem; 
    font-weight: 700; 
    color: var(--text-3); 
    margin: 0 0 1rem; 
    letter-spacing: 0.12em; 
    opacity: 0.8; 
    text-transform: uppercase;
  }

  .category-list { 
    list-style: none; 
    padding: 0; 
    margin: 0; 
    display: flex; 
    flex-direction: column; 
    gap: 0.15rem; 
  }
  
  .category-item.is-hidden {
    display: none;
  }
  
  .category-list.is-expanded .category-item.is-hidden {
    display: block;
    animation: fadeIn 0.25s ease;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .category-link {
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    padding: 0.45rem 0.6rem; 
    color: var(--text-2); 
    text-decoration: none;
    border-radius: 6px; 
    font-size: 0.85rem; 
    transition: all 0.2s;
  }
  .category-link:hover { 
    background: var(--bg-2); 
    color: var(--text); 
  }
  .category-link.active { 
    background: var(--red-faint); 
    color: var(--red); 
    font-weight: 600; 
  }
  
  .cat-name { font-weight: 500; }
  .cat-count { 
    font-size: 0.7rem; 
    color: var(--text-3); 
    font-family: 'Courier New', monospace; 
  }

  .toggle-btn {
    width: 100%; 
    background: none; 
    border: none; 
    padding: 0.6rem 0 0;
    text-align: left; 
    font-size: 0.75rem; 
    color: var(--text-3);
    cursor: pointer; 
    transition: color 0.2s;
    margin-top: 0.3rem;
  }
  .toggle-btn:hover { color: var(--red); }

  .tags-list { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 0.5rem; 
  }
  
  .tag-item {
    display: inline-flex; 
    align-items: center; 
    gap: 0.2rem;
    padding: 0.3rem 0.6rem; 
    background: var(--bg-2); 
    border: 1px solid transparent;
    border-radius: 16px; 
    font-size: 0.75rem; 
    color: var(--text-2);
    text-decoration: none; 
    transition: all 0.2s;
  }
  .tag-item:hover { 
    border-color: var(--border); 
    background: var(--bg); 
    color: var(--text); 
  }
  .tag-item.is-active {
    background: var(--red-faint);
    border-color: rgba(255, 0, 0, 0.15);
    color: var(--red);
  }
  
  .tag-symbol { 
    color: var(--text-3); 
    opacity: 0.6; 
    margin-right: 0.1rem;
  }
  .tag-item.is-active .tag-symbol {
    color: var(--red);
    opacity: 0.8;
  }
  .tag-num { 
    font-size: 0.65rem; 
    color: var(--text-3); 
    font-family: 'Courier New', monospace; 
    opacity: 0.7;
    margin-left: 0.2rem;
  }
  .tag-item.is-active .tag-num {
    color: var(--red);
    opacity: 0.8;
  }

  .content-area { 
    flex: 1; 
    min-width: 0; 
    padding-bottom: 3rem;
  }
  
  .content-header { 
    margin-bottom: 2.5rem; 
    border-left: 3px solid var(--red); 
    padding-left: 1.2rem; 
  }
  
  .content-title { 
    margin: 0 0 0.4rem; 
    font-size: 2rem; 
    font-weight: 800; 
    letter-spacing: -0.02em; 
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  
  .title-symbol {
    color: var(--red);
    font-weight: 400;
  }
  
  .content-subtitle { 
    font-size: 0.85rem; 
    color: var(--text-3); 
    font-family: 'Courier New', monospace; 
    margin: 0;
  }

  .notes-grid { 
    display: flex; 
    flex-direction: column; 
    gap: 1.25rem; 
  }
  
  .note-card {
    position: relative;
    display: flex; 
    align-items: center; 
    justify-content: space-between;
    padding: 1.5rem; 
    border: 1px solid var(--border); 
    border-radius: 10px;
    background: var(--bg); 
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .note-card:hover { 
    border-color: var(--red); 
    transform: translateY(-2px); 
    box-shadow: 0 4px 20px rgba(0,0,0,0.05); 
  }

  .card-content { 
    flex: 1; 
    min-width: 0; 
    padding-right: 1.5rem; 
  }

  .card-title-link { 
    text-decoration: none; 
    color: inherit; 
    display: inline-block;
  }
  .card-title-link::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-title { 
    font-size: 1.2rem; 
    font-weight: 600; 
    margin: 0.5rem 0 0.8rem; 
    transition: color 0.2s; 
    line-height: 1.4;
  }
  .note-card:hover .card-title { color: var(--red); }

  .card-date { 
    font-size: 0.75rem; 
    color: var(--text-3); 
    font-family: 'Courier New', monospace; 
    display: block;
  }
  
  .card-desc { 
    font-size: 0.9rem; 
    color: var(--text-2); 
    margin: 0 0 1rem; 
    line-height: 1.6; 
    display: -webkit-box; 
    -webkit-line-clamp: 2; 
    -webkit-box-orient: vertical; 
    overflow: hidden; 
    opacity: 0.9;
  }

  .card-meta { 
    display: flex; 
    align-items: center; 
    gap: 0.75rem; 
    position: relative; 
    z-index: 2;
    flex-wrap: wrap;
  }

  .meta-cat {
    font-size: 0.7rem; 
    font-weight: 600; 
    color: var(--red);
    background: var(--red-faint);
    padding: 0.2rem 0.6rem; 
    border-radius: 4px;
    text-decoration: none; 
    font-family: 'Courier New', monospace;
    transition: opacity 0.2s;
  }
  .meta-cat:hover { opacity: 0.8; }

  .meta-tags { 
    display: flex; 
    gap: 0.4rem; 
    flex-wrap: wrap; 
  }
  
  .meta-tag {
    font-size: 0.7rem; 
    color: var(--text-2); 
    background: var(--bg-2);
    padding: 0.15rem 0.5rem; 
    border-radius: 4px;
    font-family: 'Courier New', monospace; 
    text-decoration: none;
    transition: all 0.2s;
    position: relative;
    z-index: 2;
  }
  .meta-tag:hover { 
    background: var(--border); 
    color: var(--text); 
  }

  .card-arrow { 
    font-size: 1.3rem; 
    color: var(--text-3); 
    transition: all 0.2s;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .note-card:hover .card-arrow { 
    color: var(--red); 
    transform: translateX(4px); 
  }

  @media (max-width: 900px) {
    .main-layout { 
      flex-direction: column; 
      padding: 0;
      gap: 2rem;
    }
    .sidebar { 
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sidebar-box {
      flex: 1;
      min-width: 280px;
    }
    .content-area { padding-bottom: 2rem; }
    .note-card { 
      flex-direction: column; 
      align-items: flex-start;
      gap: 1rem;
    }
    .card-content { padding-right: 0; }
    .card-arrow { align-self: flex-end; }
  }
</style>