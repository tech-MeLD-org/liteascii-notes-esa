---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import PageHeader from '../components/layout/PageHeader.svelte';
import GithubCard from '../components/features/GithubCard.svelte';

// 在这里配置你的 GitHub 仓库
const repoPath = "tech-MeLD/LiteASCII"; 
const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;

let repoData = null;

// 1. 独立构建 Headers，确保 User-Agent 始终存在
const fetchHeaders = {
  "User-Agent": "Astro-LiteASCII-Site",
  "Accept": "application/vnd.github.v3+json"
};

// 2. 如果有 Token，再追加 Authorization
if (GITHUB_TOKEN) {
  fetchHeaders["Authorization"] = `Bearer ${GITHUB_TOKEN}`;
}

try {
  const response = await fetch(`https://api.github.com/repos/${repoPath}`, {
    headers: fetchHeaders
  });
  
  if (response.ok) {
    repoData = await response.json();
  } else {
    // 3. 打印详细的错误信息到终端（关键调试步骤）
    console.error(`🚨 GitHub API 错误: ${response.status} ${response.statusText}`);
    const errorData = await response.json();
    console.error("详细原因:", errorData.message);
  }
} catch (e) {
  console.error("🚨 请求发送失败:", e);
}
---

<Layout title="About · LiteASCII">
  <Header client:load />

  <main class="pt-[calc(52px+2.5rem)] max-w-3xl mx-auto px-6 pb-16">
    <PageHeader 
      client:load
      title="About" 
      subtitle="关于这个知识空间" 
    />

    <article class="prose max-w-none">
      <section class="mb-10">
        <h2 class="text-xl font-bold text-text-main mb-4">LiteASCII</h2>
        <p class="text-text-secondary mb-6">
          LiteASCII 是一个个人知识库网站，让知识在连接中生长。
        </p>
      </section>

      <section class="mb-10 not-prose"> <h2 class="text-xl font-bold text-text-main mb-5 flex items-center gap-2">
          Project Repository
        </h2>
        {repoData ? (
          <div class="grid grid-cols-1 gap-4">
             <GithubCard repoData={repoData} />
          </div>
        ) : (
          <div class="p-4 border border-dashed border-border-main rounded-lg text-text-muted text-sm font-mono text-center">
            Failed to load GitHub data...
          </div>
        )}
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-bold text-text-main mb-4">技术栈</h2>
        <ul class="list-disc list-inside text-text-secondary mb-6 space-y-2">
          <li><strong class="text-text-main">Astro</strong> — 静态站点生成器</li>
          <li><strong class="text-text-main">Svelte</strong> — 交互组件</li>
          <li><strong class="text-text-main">Tailwind CSS v4</strong> — 样式系统</li>
        </ul>
      </section>

      </article>
  </main>

  <Footer />
</Layout>