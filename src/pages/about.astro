---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.svelte';
import Footer from '../components/Footer.astro';
---

<Layout title="About · LiteASCII">
  <Navigation client:load />

  <main class="main">
    <div class="page-header">
      <h1 class="page-title">About</h1>
      <p class="page-sub">关于这个知识空间</p>
    </div>

    <article class="prose">
      <h2>LiteASCII</h2>
      <p>
        LiteASCII 是一个个人知识库网站，基于 Obsidian 笔记构建。
        通过将日常笔记发布为网站，让知识在连接中生长。
      </p>

      <h2>技术栈</h2>
      <ul>
        <li><strong>Astro</strong> — 静态站点生成器</li>
        <li><strong>Svelte</strong> — 交互组件（图谱、导航）</li>
        <li><strong>Obsidian</strong> — 笔记来源</li>
        <li><strong>Pagefind</strong> — 全文搜索</li>
      </ul>

      <h2>笔记说明</h2>
      <p>
        笔记存放于 <code>src/content/</code>，保持 Obsidian 原生目录结构。
        附件图片统一放在笔记同级的 <code>attachments/</code> 文件夹中。
      </p>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .main {
    padding-top: calc(var(--nav-h) + 2rem);
    max-width: 760px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-bottom: 3rem;
  }
  .page-header { margin-bottom: 2.5rem; }
  .page-title { margin: 0 0 0.3rem; }
  .page-sub {
    font-size: 0.82rem;
    color: var(--text-3);
    font-family: 'Courier New', monospace;
  }
</style>
