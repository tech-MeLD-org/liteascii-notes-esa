---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.svelte';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { pathToSlug, getNoteTitle, isVisibleNote } from '../utils/note-logic';

const rawNotes = await getCollection('notes');
const allNotes = rawNotes.filter(n => 
  isVisibleNote(n) && 
  !n.data.tags?.some(t => t.toLowerCase() === 'thoughts')
);

const datedNotes = allNotes.filter(n => n.data.date).sort((a, b) => new Date(b.data.date!).getTime() - new Date(a.data.date!).getTime());
const undatedNotes = allNotes.filter(n => !n.data.date).sort((a, b) => getNoteTitle(a).localeCompare(getNoteTitle(b)));

const byYear = new Map<number, typeof datedNotes>();
for (const note of datedNotes) {
  const year = new Date(note.data.date!).getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(note);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Layout title="Timeline · LiteASCII">
  <Navigation client:load />
  <main class="main">
    <div class="page-header">
      <h1 class="page-title">Timeline</h1>
      <p class="page-sub">知识积累的时间轴 · A chronological map of ideas</p>
    </div>

    {years.length > 0 && (
      <div class="timeline">
        {years.map(year => (
          <section class="year-group">
            <div class="year-label">{year}</div>
            <div class="year-items">
              {byYear.get(year)!.map(note => {
                const date = new Date(note.data.date!);
                const href = '/notes/' + pathToSlug(note.id); 
                
                return (
                  <article class="timeline-item">
                    <div class="item-dot"></div>
                    <div class="item-line"></div>
                    <div class="item-content">
                      
                      <div class="item-card card-click-wrapper">
                        <time class="item-date">{date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}</time>
                        
                        <a href={href} class="card-main-link">
                          <h3 class="item-title">{getNoteTitle(note)}</h3>
                        </a>
                        
                        {note.data.description && (
                          <p class="item-desc">{note.data.description}</p>
                        )}
                        
                        <div class="meta-group" style="margin-top: 0.6rem;">
                          {note.data.category && (
                            <a href={`/category/${note.data.category}`} class="pill-category">{note.data.category}</a>
                          )}
                          {note.data.tags && note.data.tags.length > 0 && (
                            <div class="pill-tags-group">
                              {note.data.tags.map(tag => (
                                <a href={`/tags/${tag}`} class="pill-tag">#{tag}</a>
                              ))}
                            </div>
                          )}
                          <span class="item-read">阅读 →</span>
                        </div>
                      </div>

                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}

    {undatedNotes.length > 0 && (
      <section class="undated-section">
        <h2 class="undated-title">未标日期的笔记</h2>
        <div class="undated-grid">
          {undatedNotes.map(note => (
            <a href={'/notes/' + pathToSlug(note.id)} class="undated-item">
              <span class="undated-name">{getNoteTitle(note)}</span>
              <span class="undated-folder">{note.id.includes('/') ? note.id.split('/').slice(0, -1).join('/') : 'root'}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .main { padding-top: calc(var(--nav-h) + 2rem); max-width: 860px; margin: 0 auto; padding-left: 1.5rem; padding-right: 1.5rem; padding-bottom: 3rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-title { margin: 0 0 0.3rem; }
  .page-sub { font-size: 0.82rem; color: var(--text-3); font-family: 'Courier New', monospace; }

  .timeline { margin-bottom: 3rem; }
  .year-group { margin-bottom: 2rem; }
  .year-label { font-size: 0.82rem; font-family: 'Courier New', monospace; font-weight: 700; color: var(--red); letter-spacing: 0.05em; margin-bottom: 1rem; }
  .year-items { padding-left: 1.25rem; }

  .timeline-item { display: grid; grid-template-columns: 10px 1px 1fr; gap: 0 0.75rem; margin-bottom: 1.25rem; position: relative; }
  .item-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); margin-top: 0.45rem; flex-shrink: 0; z-index: 2; }
  .item-line { background: var(--border); margin-top: 1rem; width: 1px; align-self: stretch; }
  .item-content { padding-bottom: 0.5rem; }

  .item-card {
    display: block; padding: 1rem 1.25rem; background: var(--bg-card, #1a1a1a);
    border: 1px solid var(--border); border-radius: 6px; transition: all 0.2s ease;
  }
  .item-card:hover { border-color: var(--red); transform: translateX(4px); }
  
  .item-date { font-size: 0.72rem; color: var(--text-3); font-family: 'Courier New', monospace; display: block; margin-bottom: 0.4rem; }
  .item-title { font-size: 1rem; font-weight: 600; margin: 0 0 0.3rem; line-height: 1.4; transition: color 0.2s; }
  .item-card:hover .item-title { color: var(--red); }
  .item-desc { font-size: 0.85rem; color: var(--text-2); margin: 0; line-height: 1.5; }
  
  .item-read { font-size: 0.72rem; color: var(--red); font-family: 'Courier New', monospace; opacity: 0; transition: opacity 0.2s; margin-left: auto; }
  .item-card:hover .item-read { opacity: 1; }

  .undated-section { border-top: 1px solid var(--border); padding-top: 2rem; }
  .undated-title { font-size: 0.85rem; font-weight: 600; color: var(--text-2); margin: 0 0 1rem; }
  .undated-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.6rem; }
  .undated-item { display: flex; flex-direction: column; padding: 0.8rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 5px; transition: border-color 0.2s; color: inherit; text-decoration: none; }
  .undated-item:hover { border-color: var(--red); }
  .undated-name { font-size: 0.85rem; font-weight: 500; }
  .undated-folder { font-size: 0.65rem; color: var(--text-3); margin-top: 0.3rem; }
</style>