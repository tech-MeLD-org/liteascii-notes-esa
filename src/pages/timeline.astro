---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import PageHeader from '../components/layout/PageHeader.svelte';
import TimelineContainer from '../components/layout/TimelineContainer.svelte';
import { getCollection } from 'astro:content';
import { processNotesForTimeline } from '../lib/hooks/useTimeline.svelte.ts';

const rawNotes = await getCollection('notes');
const timelineData = processNotesForTimeline(rawNotes);
---

<Layout title="Timeline · LiteASCII">
  <Header client:load />
  <main class="pt-[calc(52px+2.5rem)] max-w-3xl mx-auto px-6 pb-16">
    <PageHeader 
      title="Timeline" 
      subtitle="知识积累的时间轴 · A chronological map of ideas" 
    />

    <TimelineContainer 
      client:load 
      years={timelineData.years} 
      undated={timelineData.undated} 
    />
  </main>
  <Footer />
</Layout>