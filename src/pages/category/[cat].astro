---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.svelte';
import Footer from '../../components/layout/Footer.svelte';
import Sidebar from '../../components/layout/Sidebar.svelte';
import NoteList from '../../components/features/NoteList.svelte';
import PageHeader from '../../components/layout/PageHeader.svelte';
import { getCollection } from 'astro:content';
import { isVisibleNote, extractTitle, noteSlug, formatDate, countCategories, countTags } from '../../lib/core/note-logic';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  const validNotes = allNotes.filter(isVisibleNote);
  
  const categoryMap = countCategories(validNotes);
  const tagMap = countTags(validNotes);

  const categories = Array.from(categoryMap.entries())
    .sort(([,a], [,b]) => b - a)
    .map(([name]) => name);

  const totalNotes = allNotes.length;
  
  return categories.map((cat) => {
    const filteredNotes = validNotes.filter((note) => 
      note.data.category === cat
    ).sort((a, b) => {
      const da = a.data.date ? new Date(a.data.date).getTime() : 0;
      const db = b.data.date ? new Date(b.data.date).getTime() : 0;
      return db - da;
    });
    
    return {
      params: { cat },
      props: { 
        notes: filteredNotes, 
        cat,
        totalNotes,
        categoryMap,
        tagMap
      },
    };
  });
}

const { cat } = Astro.params;
const { notes, totalNotes, categoryMap, tagMap } = Astro.props;

const categories = Array.from(categoryMap.entries())
  .sort(([,a], [,b]) => b - a)
  .map(([name, count]) => ({ name, href: `/category/${encodeURIComponent(name)}`, count }));

const tags = Array.from(tagMap.entries())
  .sort(([,a], [,b]) => b - a)
  .map(([name, count]) => ({ name, href: `/tags/${encodeURIComponent(name)}`, count }));

const noteListData = notes.map(note => ({
  title: extractTitle(note),
  href: `/notes/${noteSlug(note.id)}`,
  date: formatDate(note.data.date),
  description: note.data.description,
  category: note.data.category as string | undefined,
  tags: note.data.tags || [],
}));
---

<Layout title={`Category: ${cat} · LiteASCII`}>
  <Header client:load />
  
  <div class="pt-[calc(52px+2.5rem)] px-4 pb-16">
    <div class="flex w-full max-w-[1200px] mx-auto gap-10 items-start flex-col lg:flex-row">
      
      <aside class="w-full lg:w-[260px] flex-shrink-0">
        <Sidebar
          client:load
          noteCount={totalNotes}
          categoryCount={categoryMap.size}
          tagCount={tagMap.size}
          {categories}
          {tags}
          currentCategory={cat}
          currentPath={`/category/${cat}`}
        />
      </aside>

      <main class="flex-1 min-w-0 pb-12">
        <PageHeader
          client:load
          title={`[${cat}]`}
          subtitle={`${notes.length} notes found in this category`}
        />

        <NoteList 
          client:load
          notes={noteListData}
          emptyText="该分类下暂无笔记"
          highlightCategory={cat}
        />
      </main>
      
    </div>
  </div>

  <Footer />
</Layout>