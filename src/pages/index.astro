---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.svelte';
import Sidebar from '../components/layout/Sidebar.svelte';
import AsciiArt from '../components/features/AsciiArt.svelte';
import NoteCard from '../components/features/NoteCard.svelte';
import { getCollection } from 'astro:content';
import { extractTitle, noteSlug, countCategories, countTags, sortByDate } from '../lib/core/note-logic';



const allNotes = await getCollection('notes');

const sorted = sortByDate(allNotes);
const recent = sorted.slice(0, 6);

// 统计数据
const noteCount = allNotes.length;

// 统计分类
const categoryMap = countCategories(allNotes);
const allCategories = Array.from(categoryMap.entries())
  .sort(([,a], [,b]) => b - a)
  .map(([name, count]) => ({ name, href: `/category/${name.replace(/\s+/g, '-')}`, count }))
  .slice(0, 8);

// 统计标签
const tagMap = countTags(allNotes);
const allTags = Array.from(tagMap.entries())
  .sort(([,a], [,b]) => b - a)
  .map(([name, count]) => ({ name, href: `/tags/${name.replace(/\s+/g, '-')}`, count }))
  .slice(0, 20);
---

<Layout title="LiteASCII">
  <Header client:load />
  
  <div class="pt-[calc(52px+2.5rem)] px-4 pb-16">
    <div class="flex w-full max-w-[1200px] mx-auto gap-10 items-start flex-col lg:flex-row">
      
      <!-- 左侧边栏 -->
      <aside class="w-full lg:w-[260px] flex-shrink-0">
        <Sidebar
          client:load
          noteCount={noteCount}
          categoryCount={categoryMap.size}
          tagCount={tagMap.size}
          categories={allCategories}
          tags={allTags}
        />
      </aside>

      <!-- 右侧内容区 -->
      <main class="flex-1 min-w-0 pb-8 w-full">
        <!-- ASCII 动画 Hero -->
        <section class="border border-border rounded-xl bg-bg p-8 mb-10 flex flex-col items-center">
          <div class="w-full flex justify-center items-center min-h-[200px]">
            <AsciiArt client:only="svelte" noteCount={noteCount} />
          </div>
          <div class="flex justify-center gap-8 mt-6 pt-6 border-t border-border w-full">
            <div class="flex flex-col items-center gap-1">
              <span class="text-2xl font-bold text-text font-mono">{noteCount}</span>
              <span class="text-xs text-text-muted uppercase tracking-wider">Notes</span>
            </div>
            <div class="flex flex-col items-center gap-1">
              <span class="text-2xl font-bold text-text font-mono">{categoryMap.size}</span>
              <span class="text-xs text-text-muted uppercase tracking-wider">Categories</span>
            </div>
            <div class="flex flex-col items-center gap-1">
              <span class="text-2xl font-bold text-text font-mono">{tagMap.size}</span>
              <span class="text-xs text-text-muted uppercase tracking-wider">Tags</span>
            </div>
          </div>
        </section>

        <!-- Recent Notes -->
        <section>
          <div class="flex items-baseline justify-between mb-5 border-l-[3px] border-primary pl-4">
            <h2 class="text-lg font-bold text-text tracking-tight">Recent Notes</h2>
            <a href="/notes" class="text-sm text-primary font-mono hover:text-text transition-colors">All notes →</a>
          </div>
          
          {noteCount === 0 ? (
            <p class="text-sm text-text-muted py-8 text-center border border-dashed border-border rounded-lg bg-bg">
              将 Obsidian 笔记放入 <code class="text-primary bg-primary-faint px-1.5 py-0.5 rounded font-mono">src/content/</code> 即可显示
            </p>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {recent.map(note => (
                <NoteCard
                  client:load
                  title={extractTitle(note)}
                  href={`/notes/${noteSlug(note.id)}`}
                  date={note.data.date ? new Date(note.data.date).toLocaleDateString('zh-CN') : undefined}
                  description={note.data.description}
                  tags={note.data.tags}
                  category={note.data.category} 
                />
              ))}
            </div>
          )}
        </section>
      </main>
      
    </div>
  </div>

  <Footer />
</Layout>